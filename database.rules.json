{
  "rules": {
    "rooms": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['id', 'nickname', 'title', 'spaces']) && newData.child('id').val() == $uid"
      }
    },
    "guestbooks": {
      "$roomId": {
        ".read": true,
        "$noteId": {
          ".write": "auth != null && ((!data.exists() && newData.child('by').val() == auth.uid && newData.hasChildren(['name', 'by', 'msg', 'at'])) || (data.exists() && !newData.exists() && (data.child('by').val() == auth.uid || auth.uid == $roomId)))",
          ".validate": "!newData.exists() || (newData.child('msg').isString() && newData.child('msg').val().length > 0 && newData.child('msg').val().length <= 200 && newData.child('name').isString() && newData.child('name').val().length <= 10)"
        }
      }
    },
    "probe": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
